# Firebase Configuration
# These will be set using firebase functions:config:set

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SMTP Configuration (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=orders@ficishoes.com
SMTP_PASSWORD=your_smtp_password
FROM_NAME=FiCi Shoes
FROM_EMAIL=orders@ficishoes.com

# OTP Configuration
OTP_SECRET=your_very_secure_otp_secret_key_here
OTP_TTL_MINUTES=10
OTP_LENGTH=6
MAX_SENDS_PER_HOUR=3
MAX_VERIFICATION_ATTEMPTS=3

# Application Configuration
APP_URL=https://www.ficishoes.com
